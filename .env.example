BOT_TOKEN=你的Telegram机器人Token

# 运行模式：polling（推荐，无域名也能用）或 webhook（有域名 / Cloudflare Tunnel 时用）
# RUN_MODE=polling

# 只有 RUN_MODE=webhook 时才需要填写。
# WEBHOOK_URL=https://xxxx.trycloudflare.com/telegram

# 本机监听地址和端口，默认一般不用改。
WEBHOOK_LISTEN=127.0.0.1
WEBHOOK_PORT=8080
WEBHOOK_PATH=telegram

# 可选：Telegram 用来校验 webhook 的密钥。
WEBHOOK_SECRET_TOKEN=

# 保存双向会话和用户状态的文件。
PERSISTENCE_PATH=bot_state.pickle

# 客服超级群 ID，必须填，才能启用“双向人工接管”。
ADMIN_GROUP_CHAT_ID=

# 允许在客服群里回复的管理员 Telegram 用户 ID，多个用英文逗号分隔。
ADMIN_USER_IDS=

# 进入/退出人工模式的关键词。
HANDOFF_KEYWORD=双向
HANDOFF_EXIT_KEYWORD=单向

# 回复模式：rules / ai / hybrid
REPLY_MODE=hybrid
DEFAULT_REPLY=收到，我在。

# AI 中转站配置，使用 AI 才需要填写。
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
SYSTEM_PROMPT=You are a concise, helpful Telegram bot.

# 关键词图片路径，按需填写。
IMAGE_PATH=
MENU_IMAGE=
PRICE_IMAGE=
LOCATION_IMAGE=
SUPPORT_IMAGE=
